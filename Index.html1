<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Digital Stamp</title>
<style>
body{font-family:Arial;margin:20px}
button{padding:10px 20px;font-size:16px;cursor:pointer}
#page{
width:100%;
height:500px;
border:2px solid #999;
margin-top:15px;
position:relative;
background:#fff;
overflow:hidden;
}
.stamp{
position:absolute;
width:120px;
height:120px;
border:4px solid #003399;
border-radius:50%;
color:#003399;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
font-weight:bold;
font-size:18px;
background:rgba(255,255,255,.8);
cursor:move;
user-select:none;
}
.stamp small{
display:block;
font-size:10px;
}
</style>
</head>
<body>

<button onclick="mode=!mode">
Stamp Mode ON/OFF
</button>

<div id="page"></div>

<script>
let mode=false;

page.onclick=function(e){
if(!mode)return;

let s=document.createElement("div");
s.className="stamp";
s.style.left=(e.offsetX-60)+"px";
s.style.top=(e.offsetY-60)+"px";
s.innerHTML="MUMBAI<br><small>SHREE VAIBHAVLAXMI<br>ENTERPRISES</small>";

page.appendChild(s);

drag(s);
}

function drag(el){
let x,y;
el.onmousedown=function(e){
x=e.offsetX;
y=e.offsetY;
document.onmousemove=function(ev){
el.style.left=(ev.pageX-page.offsetLeft-x)+"px";
el.style.top=(ev.pageY-page.offsetTop-y)+"px";
}
document.onmouseup=function(){
document.onmousemove=null;
}
}
}
</script>

</body>
</html>
